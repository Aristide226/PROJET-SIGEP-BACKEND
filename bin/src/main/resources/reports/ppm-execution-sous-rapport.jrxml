	<parameter name="IdPPM_PARAM" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
                  dbo.PPM_EXEC.IdPPMExe, dbo.PPM_EXEC.IdLot, dbo.PPM_EXEC.IdBudget, dbo.PPM_EXEC.Exercice, dbo.PPM_EXEC.NbLot, dbo.PPM_EXEC.Num, dbo.PPM_EXEC.MontantEstime, dbo.PPM_EXEC.MontDepEngNonLia, 
                  dbo.PPM_EXEC.CreditDispo, dbo.PPM_EXEC.NatPrestation, dbo.PPM_EXEC.ObjetLot, dbo.PPM_EXEC.DateCreat, dbo.PPM_EXEC.DateLanceEffect, dbo.PPM_EXEC.DateButoire, dbo.PPM_EXEC.Execut, dbo.PPM_EXEC.IdFourm, 
                  dbo.PPM_EXEC.MontantAttrib, dbo.PPM_EXEC.MontantTotalTTC, dbo.PPM_EXEC.MontantTotalHTVA, dbo.PPM_EXEC.MontantMaxTTC, dbo.PPM_EXEC.MontantMaxHTVA, dbo.PPM_EXEC.MontantMinTTC, 
                  dbo.PPM_EXEC.MontantMinHTVA, dbo.PPM_EXEC.IdModPassation, dbo.PPM_EXEC.DateNotificationProvisoire, dbo.PPM_EXEC.DateApprobContrat, dbo.PPM_EXEC.NiveauMiseEnOeuvreEtObservation, dbo.PPM_EXEC.DateReception, 
                  dbo.PPM_EXEC.DateLancementMarchePrevisionnel, dbo.PPM_EXEC.NbJoursRetardLancement, dbo.PPM_EXEC.IdPPM as IdPPM, dbo.EnteteS.niveau1, dbo.EnteteS.niveau2, dbo.EnteteS.niveau3, dbo.EnteteStructureS.libAnnee, 
                  dbo.EnteteStructureS.lieu, dbo.EnteteStructureS.nomPays, dbo.Destinataires.IdDest, dbo.Destinataires.fType, dbo.Destinataires.Nom
FROM     dbo.Destinataires INNER JOIN
                  dbo.PPM_EXEC ON dbo.Destinataires.IdDest = dbo.PPM_EXEC.IdFourm CROSS JOIN
                  dbo.EnteteStructureS INNER JOIN
                  dbo.EnteteS ON dbo.EnteteStructureS.abrevEpe = dbo.EnteteS.abrevEpe
WHERE  (dbo.Destinataires.fType = 'F') and ( IdPPM= $P{IdPPM_PARAM}) AND  (dbo.EnteteS.codUser = 'PRM')]]>
	</queryString>
