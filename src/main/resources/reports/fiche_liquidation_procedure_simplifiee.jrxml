	<parameter name="GESTION" class="java.lang.Integer"/>
	<parameter name="IDBUDGET" class="java.lang.Integer"/>
	<parameter name="BENUM" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT        dbo.Engagements.Gestion, dbo.Engagements.BENum, dbo.Engagements.Proced, dbo.Engagements.Date_Creat, dbo.Engagements.DateCreation, dbo.Engagements.NatDepense, dbo.Engagements.Montant, 
                         dbo.Engagements.Dot_Initiale, dbo.Engagements.DispoAvant, ISNULL(dbo.Engagements.DispoAvant - dbo.Engagements.Montant, 0) AS Disponible, dbo.BudgetType.LibelleBudget, dbo.NomenclatureD.Chap, 
                         dbo.NomenclatureD.Art, dbo.NomenclatureD.Parag, dbo.NomenclatureD.Rub, dbo.NomenclatureD.Intitule, dbo.Destinataires.IFUMle, dbo.Destinataires.Nom, dbo.EnteteS.niveau1, dbo.EnteteS.niveau2, dbo.EnteteS.niveau3, 
                         dbo.EnteteS.niveau4, dbo.EnteteStructureS.libAnnee, dbo.EnteteStructureS.lieu, dbo.EnteteStructureS.logo, dbo.EnteteStructureS.nomSignataireAc, dbo.EnteteStructureS.nomSignataireDaf, dbo.EnteteStructureS.nomSignataireDg, 
                         dbo.EnteteStructureS.signataireAc, dbo.EnteteStructureS.signataireDaf, dbo.EnteteStructureS.signataireDg, dbo.EnteteStructureS.titreHonorifiqueAc, dbo.EnteteStructureS.titreHonorifiqueDaf, 
                         dbo.EnteteStructureS.titreHonorifiqueDg, dbo.EnteteStructureS.visa, dbo.PieceJustif.PieceJustificative, dbo.PieceJustif.Numero AS PieceJustifNumero, dbo.PieceJustif.DatePj, dbo.PieceJustif.Montant AS PieceJustifMontant, 
                         dbo.Mandats.MandNum, dbo.Mandats.DateMand, dbo.Mandats.CompteFourn, dbo.Mandats.Montant AS MontantMandat, dbo.Mandats.NumBL, dbo.Mandats.MontEngage, dbo.Mandats.MontDjaLiq, dbo.CompteDestinataire.Abreviation, 
                         dbo.InstitutFinAgence.LibelleAgence, dbo.CompteDestinataire.CodeBanque, dbo.CompteDestinataire.CodeAgence, dbo.CompteDestinataire.NumCompte, dbo.CompteDestinataire.CleRIB
FROM            dbo.PieceJustif LEFT OUTER JOIN
                         dbo.Engagements ON dbo.Engagements.NumBE = dbo.PieceJustif.NumBE LEFT OUTER JOIN
                         dbo.BudgetType ON dbo.Engagements.IdBudget = dbo.BudgetType.IdBudget LEFT OUTER JOIN
                         dbo.Budget ON dbo.Engagements.CodBud = dbo.Budget.CodBud LEFT OUTER JOIN
                         dbo.NomenclatureD ON dbo.Budget.NumNo = dbo.NomenclatureD.NumNo LEFT OUTER JOIN
                         dbo.Destinataires ON dbo.Engagements.idFourn = dbo.Destinataires.IdDest LEFT OUTER JOIN
                         dbo.AccesCode ON dbo.AccesCode.UserName = dbo.Engagements.IdUser LEFT OUTER JOIN
                         dbo.EnteteS ON dbo.EnteteS.codUser = dbo.AccesCode.Code LEFT OUTER JOIN
                         dbo.EnteteStructureS ON dbo.EnteteStructureS.abrevEpe = dbo.EnteteS.abrevEpe LEFT OUTER JOIN
                         dbo.Mandats ON dbo.Engagements.NumBE = dbo.Mandats.NumBE LEFT OUTER JOIN
                         dbo.CompteDestinataire ON dbo.Mandats.CompteFourn = dbo.CompteDestinataire.id LEFT OUTER JOIN
                         dbo.InstitutFinAgence ON dbo.CompteDestinataire.IdAgence = dbo.InstitutFinAgence.IdAgence
WHERE        (dbo.Engagements.Gestion = $P{GESTION}) AND (dbo.Engagements.IdBudget =$P{IDBUDGET} )  AND (dbo.Engagements.BENum = $P{BENUM})]]>
	</queryString>
