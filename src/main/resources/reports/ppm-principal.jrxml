	<queryString language="SQL">
		<![CDATA[SELECT dbo.PPM_BUDG.IdPPM, dbo.PPM_BUDG.CodBud, dbo.PPM_BUDG.IdSrceFin, dbo.PPM_BUDG.MontantEstime, dbo.PPM.IdBudget, dbo.PPM.Exercice, dbo.PPM.MontDepEngNonLiq, dbo.PPM.CreditDispo, dbo.PPM.NatPrestation, 
                  dbo.PPM.NbLot, dbo.PPM.IdModPassation, dbo.PPM.DateLancement, dbo.PPM.DateRemiseOffre, dbo.PPM.NbJrsEvaluation, dbo.PPM.DateProbDemar, dbo.PPM.DelaiExecJrs, dbo.PPM.DateButoire, dbo.PPM.DateEffectLance, 
                  dbo.PPM.DateAttribution, dbo.PPM.MontantPasse, dbo.PPM.IdPPM_M, dbo.CodSourceFin.IntituleCourt, dbo.AccesCode.Code, dbo.EnteteS.codUser, dbo.EnteteS.niveau1, dbo.EnteteS.niveau2, dbo.EnteteS.niveau3, dbo.EnteteS.niveau4, 
                  dbo.EnteteStructureS.devisePays, dbo.EnteteStructureS.lieu, dbo.EnteteStructureS.logo, dbo.EnteteStructureS.nomPays
FROM     dbo.PPM_BUDG LEFT OUTER JOIN
                  dbo.PPM ON dbo.PPM_BUDG.IdPPM = dbo.PPM.IdPPM LEFT OUTER JOIN
                  dbo.Budget ON dbo.PPM_BUDG.CodBud = dbo.Budget.CodBud LEFT OUTER JOIN
                  dbo.CodSourceFin ON dbo.PPM_BUDG.IdSrceFin = dbo.CodSourceFin.Cod5 LEFT OUTER JOIN
                  dbo.PPM_Acte ON dbo.PPM.IdPPM_M = dbo.PPM_Acte.IdPPM_M LEFT OUTER JOIN
                  dbo.AccesCode ON dbo.PPM_Acte.UserCreate = dbo.AccesCode.UserName LEFT OUTER JOIN
                  dbo.EnteteS ON dbo.AccesCode.Code = dbo.EnteteS.codUser LEFT OUTER JOIN
                  dbo.EnteteStructureS ON dbo.EnteteStructureS.abrevEpe = dbo.EnteteS.abrevEpe
                  
 WHERE dbo.PPM.Exercice = $P{anneePPM} AND dbo.EnteteS.codUser = 'PRM']]>
	</queryString>
