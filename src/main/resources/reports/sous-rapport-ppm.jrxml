	<parameter name="IdPPM_PARAM" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT DISTINCT
    dbo.PPM.IdPPM, dbo.PPM.IdBudget, dbo.PPM.Exercice, dbo.PPM.MontDepEngNonLiq, dbo.PPM.CreditDispo, dbo.PPM.NatPrestation, dbo.PPM.NbLot, dbo.PPM.IdModPassation, dbo.PPM.DateLancement, dbo.PPM.DateRemiseOffre,
    dbo.PPM.NbJrsEvaluation, dbo.PPM.DateProbDemar, dbo.PPM.DelaiExecJrs, dbo.PPM.DateButoire, dbo.PPM.DateEffectLance, dbo.PPM.DateAttribution, dbo.PPM.MontantPasse, dbo.PPM.IdPPM_M, dbo.PPM_BUDG.CodBud,
    dbo.PPM_BUDG.IdSrceFin, dbo.PPM_BUDG.MontantEstime, dbo.CodSourceFin.IntituleCourt, dbo.Budget.IdPlan
FROM    dbo.PPM INNER JOIN
        dbo.PPM_BUDG ON dbo.PPM.IdPPM = dbo.PPM_BUDG.IdPPM INNER JOIN
        dbo.CodSourceFin ON dbo.PPM_BUDG.IdSrceFin = dbo.CodSourceFin.Cod5 INNER JOIN
        dbo.Budget ON dbo.PPM_BUDG.CodBud = dbo.Budget.CodBud
WHERE  dbo.PPM.IdPPM = $P{IdPPM_PARAM}]]>
	</queryString>
