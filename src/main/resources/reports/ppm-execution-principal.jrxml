	<parameter name="anneePPM" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_PARAM" class="net.sf.jasperreports.engine.JasperReport"/>
	<queryString language="SQL">
		<![CDATA[SELECT dbo.PPM_EXEC_BUDG.IdPPMExe, dbo.PPM_EXEC_BUDG.IdLot, dbo.PPM_EXEC_BUDG.IdBudget, dbo.PPM_EXEC_BUDG.Exercice, dbo.PPM_EXEC_BUDG.CodBud, dbo.PPM_EXEC_BUDG.IdSrceFin, dbo.PPM_EXEC_BUDG.MontantEstime, 
                  dbo.PPM_EXEC_BUDG.MontantMaxHTVA, dbo.PPM_EXEC_BUDG.MontantMinHTVA, dbo.PPM_EXEC_BUDG.MontantMaxTTC, dbo.PPM_EXEC_BUDG.MontantMinTTC, dbo.PPM_EXEC_BUDG.AvecTVA, 
                  dbo.PPM_EXEC_BUDG.AvecMiniMax, dbo.PPM_EXEC.NbLot, dbo.PPM_EXEC.Num, dbo.PPM_EXEC.MontDepEngNonLia, dbo.PPM_EXEC.NatPrestation, dbo.PPM_EXEC.ObjetLot, dbo.PPM_EXEC.DateCreat, 
                  dbo.PPM_EXEC.DateLanceEffect, dbo.PPM_EXEC.DateButoire, dbo.PPM_EXEC.Execut, dbo.PPM_EXEC.IdFourm, dbo.PPM_EXEC.MontantAttrib, dbo.PPM_EXEC.MontantTotalTTC, dbo.PPM_EXEC.MontantTotalHTVA, 
                  dbo.PPM_EXEC.IdModPassation, dbo.PPM_EXEC.DateNotificationProvisoire, dbo.PPM_EXEC.DateApprobContrat, dbo.PPM_EXEC.NiveauMiseEnOeuvreEtObservation, dbo.PPM_EXEC.DateReception, 
                  dbo.PPM_EXEC.DateLancementMarchePrevisionnel, dbo.PPM_EXEC.NbJoursRetardLancement, dbo.PPM_EXEC.IdPPM, dbo.PPM_EXEC.DateRemiseEtOuvertureDesPlis, dbo.Budget.Gestion, dbo.Budget.IdPlan, dbo.Destinataires.IdDest, 
                  dbo.Destinataires.fType, dbo.Destinataires.Nom, dbo.EnteteStructureS.devisePays, dbo.EnteteStructureS.lieu, dbo.EnteteStructureS.logo, dbo.EnteteStructureS.nomPays, dbo.EnteteStructureS.libAnnee, dbo.EnteteS.niveau1, 
                  dbo.EnteteS.niveau2, dbo.EnteteS.niveau3, dbo.EnteteS.niveau4
FROM     dbo.PPM_EXEC_BUDG LEFT OUTER JOIN
                  dbo.PPM_EXEC ON dbo.PPM_EXEC.IdPPMExe = dbo.PPM_EXEC_BUDG.IdPPMExe AND dbo.PPM_EXEC.IdLot = dbo.PPM_EXEC_BUDG.IdLot AND dbo.PPM_EXEC.IdBudget = dbo.PPM_EXEC_BUDG.IdBudget AND 
                  dbo.PPM_EXEC.Exercice = dbo.PPM_EXEC_BUDG.Exercice AND dbo.PPM_EXEC.IdPPMExe = dbo.PPM_EXEC_BUDG.IdPPMExe LEFT OUTER JOIN
                  dbo.Budget ON dbo.PPM_EXEC_BUDG.CodBud = dbo.Budget.CodBud LEFT OUTER JOIN
                  dbo.Destinataires ON dbo.Destinataires.IdDest = dbo.PPM_EXEC.IdFourm CROSS JOIN
                  dbo.EnteteStructureS LEFT OUTER JOIN
                  dbo.EnteteS ON dbo.EnteteStructureS.abrevEpe = dbo.EnteteS.abrevEpe
WHERE  (dbo.EnteteS.codUser = 'PRM') 	AND (dbo.Destinataires.fType = 'F') AND (dbo.PPM_EXEC.Exercice = $P{anneePPM})]]>
	</queryString>
