<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="visibilité-de-prm-principal" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="843c0e5a-73ad-40be-b5cf-220d309387c8">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="gbc"/>
	<parameter name="anneePPM" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_PARAM" class="net.sf.jasperreports.engine.JasperReport"/>
	<queryString language="SQL">
		<![CDATA[SELECT dbo.PPM_EXEC.IdPPMExe, dbo.PPM_EXEC.IdLot, dbo.PPM_EXEC.IdBudget, dbo.PPM_EXEC.Exercice, dbo.PPM_EXEC.NbLot, dbo.PPM_EXEC.Num, dbo.PPM_EXEC.MontantEstime, dbo.PPM_EXEC.MontDepEngNonLia, 
                  dbo.PPM_EXEC.CreditDispo, dbo.PPM_EXEC.NatPrestation, dbo.PPM_EXEC.ObjetLot, dbo.PPM_EXEC.DateCreat, dbo.PPM_EXEC.DateLanceEffect, dbo.PPM_EXEC.DateButoire, dbo.PPM_EXEC.Execut, dbo.PPM_EXEC.IdFourm, 
                  dbo.PPM_EXEC.MontantAttrib, dbo.PPM_EXEC.MontantTotalTTC, dbo.PPM_EXEC.MontantTotalHTVA, dbo.PPM_EXEC.MontantMaxTTC, dbo.PPM_EXEC.MontantMaxHTVA, dbo.PPM_EXEC.MontantMinTTC, 
                  dbo.PPM_EXEC.MontantMinHTVA, dbo.PPM_EXEC.IdModPassation, dbo.PPM_EXEC.DateNotificationProvisoire, dbo.PPM_EXEC.DateApprobContrat, dbo.PPM_EXEC.NiveauMiseEnOeuvreEtObservation, dbo.PPM_EXEC.DateReception, 
                  dbo.PPM_EXEC.DateLancementMarchePrevisionnel, dbo.PPM_EXEC.NbJoursRetardLancement, dbo.PPM_EXEC.IdPPM, dbo.EnteteS.niveau1, dbo.EnteteS.niveau2, dbo.EnteteS.niveau3, dbo.EnteteStructureS.libAnnee, 
                  dbo.EnteteStructureS.lieu, dbo.EnteteStructureS.logo, dbo.EnteteStructureS.nomPays, dbo.Destinataires.IdDest, dbo.Destinataires.fType, dbo.Destinataires.Nom, dbo.PPM_EXEC_BUDG.CodBud, dbo.PPM_EXEC_BUDG.IdSrceFin, 
                  dbo.Budget.IdPlan, dbo.Budget.Gestion, dbo.EnteteStructureS.devisePays, dbo.PPM_EXEC.DateRemiseEtOuvertureDesPlis
FROM     dbo.Destinataires INNER JOIN
                  dbo.PPM_EXEC ON dbo.Destinataires.IdDest = dbo.PPM_EXEC.IdFourm INNER JOIN
                  dbo.PPM_EXEC_BUDG ON dbo.PPM_EXEC.IdPPMExe = dbo.PPM_EXEC_BUDG.IdPPMExe AND dbo.PPM_EXEC.IdLot = dbo.PPM_EXEC_BUDG.IdLot AND dbo.PPM_EXEC.IdBudget = dbo.PPM_EXEC_BUDG.IdBudget AND 
                  dbo.PPM_EXEC.Exercice = dbo.PPM_EXEC_BUDG.Exercice AND dbo.PPM_EXEC.IdPPMExe = dbo.PPM_EXEC_BUDG.IdPPMExe INNER JOIN
                  dbo.Budget ON dbo.PPM_EXEC_BUDG.CodBud = dbo.Budget.CodBud AND dbo.PPM_EXEC_BUDG.CodBud = dbo.Budget.CodBud CROSS JOIN
                  dbo.EnteteStructureS INNER JOIN
                  dbo.EnteteS ON dbo.EnteteStructureS.abrevEpe = dbo.EnteteS.abrevEpe
WHERE  (dbo.EnteteS.codUser = 'PRM') AND (dbo.Destinataires.fType = 'F') AND (dbo.PPM_EXEC.Exercice = $P{anneePPM})
]]>
	</queryString>
